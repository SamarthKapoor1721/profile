NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-10-01
SANITY_API_READ_TOKEN=
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Contact form — recipient address used by serverless API route
# Set CONTACT_TO_EMAIL to the address that should receive form submissions
CONTACT_TO_EMAIL=kapoorsammy05@gmail.com
# Optional: the "from" address used when sending via Resend
CONTACT_FROM_EMAIL=onboarding@resend.dev
# Required to actually send emails with Resend — leave empty for local/dev
RESEND_API_KEY=

# Admin panel (/admin) — password to add/edit projects, experience, certifications.
# Used only when running locally; writes are blocked on Vercel (read-only FS).
# Defaults to "admin" locally if left unset.
ADMIN_PASSWORD=
